# ─── LLM Configuration ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here        # Required unless USE_LOCAL_LLM=true
LLM_MODEL=gpt-4o                              # Model name passed to ChatOpenAI
LLM_TEMPERATURE=0.2                           # Lower = more deterministic output

# ─── Offline / Air-Gapped Mode (Ollama) ───────────────────────────────────────
# Set USE_LOCAL_LLM=true to replace ChatOpenAI with a local Ollama model.
# Requires: ollama pull llama3  (or whichever model you specify below)
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL=llama3                        # Any model pulled via `ollama pull`
OLLAMA_BASE_URL=http://localhost:11434        # Default Ollama API endpoint

# ─── OSINT Configuration ──────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key-here      # Required unless USE_LOCAL_OSINT=true

# Set USE_LOCAL_OSINT=true to use searchsploit (Kali exploitdb) instead of Tavily.
# Requires: sudo apt install exploitdb  (pre-installed on Kali)
USE_LOCAL_OSINT=false

# ─── Telegram Notifications (optional) ───────────────────────────────────────
# When set, RTAI sends a full engagement report to your Telegram bot after
# every swarm run, and an approval-request alert before any fix can execute.
#
# Setup:
#   1. Message @BotFather on Telegram → /newbot → copy the token below
#   2. Start a chat with your new bot (or add it to a group)
#   3. Message @userinfobot to get your personal chat ID
#
# If left blank, Telegram notifications are silently skipped — the pipeline
# and Approval Gate work normally without them.
TELEGRAM_BOT_TOKEN=                           # e.g. 123456789:AAFxxxxxx
TELEGRAM_CHAT_ID=                             # e.g. 6503192923

# ─── Engagement Configuration ─────────────────────────────────────────────────
# Comma-separated IPs, hostnames, or CIDR ranges that are in scope.
# e.g. 10.0.0.1  or  10.0.0.0/24  or  host.example.com
TARGET_SCOPE=
ENGAGEMENT_NAME=RTAI_Engagement               # Used as a label in reports

# ─── Self-Scan ────────────────────────────────────────────────────────────────
# When True, force-includes 127.0.0.1 and the machine's primary LAN IP in every
# scan, even if they don't respond to discovery probes (ARP/ping). Useful when
# testing the host running RTAI itself.
SCAN_SELF=false
