# ─── LLM Configuration ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here        # Required — get from platform.openai.com
LLM_MODEL=gpt-4o                              # Model name passed to ChatOpenAI
LLM_TEMPERATURE=0.2                           # Lower = more deterministic output

# ─── OSINT Configuration ──────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key-here      # Required — get from app.tavily.com

# ─── Telegram Notifications (optional) ───────────────────────────────────────
# When set, SwarmController sends an approval-request message after the Fixer
# Agent generates scripts.  Fixes cannot be applied until the operator clicks
# "Approve" in the Streamlit Dashboard.
#
# 1. Create a bot via @BotFather → copy the token below.
# 2. Start a chat with the bot (or add it to a group/channel).
# 3. Get your chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=                           # e.g. 123456789:AAFxxxxxx
TELEGRAM_CHAT_ID=                             # e.g. -1001234567890

# ─── Engagement Configuration ─────────────────────────────────────────────────
# Comma-separated IPs, hostnames, or CIDR ranges that are in scope.
# e.g. 10.0.0.1  or  10.0.0.0/24  or  host.example.com
TARGET_SCOPE=
ENGAGEMENT_NAME=RTAI_Engagement               # Used as a label in reports
